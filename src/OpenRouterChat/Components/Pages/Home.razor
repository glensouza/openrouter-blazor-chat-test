@page "/"
@rendermode InteractiveServer
@inject OpenRouterService OpenRouterSvc
@inject DocumentService DocumentSvc
@inject IOptions<OpenRouterSettings> SettingsOptions
@inject IJSRuntime Js

<PageTitle>OpenRouter Chat</PageTitle>

<div class="chat-container">
    <div class="chat-header">
        <h2>🤖 OpenRouter Chat</h2>
        <p class="text-muted">Chat with free OpenRouter models with optional document context (RAG)</p>
        <a href="/comparison" class="btn btn-outline-primary">⚔️ Model Comparison</a>
    </div>

    <!-- Model and Document Settings -->
    <div class="card mb-3 settings-card">
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-md-5">
                    <label class="form-label fw-semibold">Model</label>
                    <select class="form-select" @bind="SelectedModelId" disabled="@isSending">
                        @foreach (ModelInfo model in settings.Models)
                        {
                            <option value="@model.Id">@model.DisplayName</option>
                        }
                    </select>
                </div>
                <div class="col-md-5">
                    <label class="form-label fw-semibold">
                        📄 Context Document
                        @if (contextDocument != null)
                        {
                            <span class="badge bg-success ms-1">Loaded</span>
                        }
                    </label>
                    <InputFile class="form-control" OnChange="HandleFileUploadAsync" accept=".txt,.md,.csv,.json,.xml,.html,.htm,.pdf" disabled="@isSending" />
                    @if (!string.IsNullOrEmpty(fileError))
                    {
                        <div class="text-danger small mt-1">@fileError</div>
                    }
                </div>
                <div class="col-md-2">
                    @if (contextDocument != null)
                    {
                        <button class="btn btn-outline-danger w-100" @onclick="ClearDocument" disabled="@isSending">
                            🗑️ Clear Doc
                        </button>
                    }
                </div>
            </div>

            @if (contextDocument != null)
            {
                <div class="context-preview mt-2">
                    <small class="text-muted fw-semibold">📎 @contextFileName — @contextDocument.Length.ToString("N0") characters loaded as context</small>
                </div>
            }
        </div>
    </div>

    <!-- Chat Messages -->
    <div class="chat-messages card mb-3" @ref="messagesContainer">
        <div class="card-body p-3">
            @if (messages.Count == 0)
            {
                <div class="text-center text-muted py-5">
                    <div class="display-6 mb-2">💬</div>
                    <p>Start a conversation! Select a model above and type your message below.</p>
                    @if (contextDocument != null)
                    {
                        <p class="text-success">✅ Document context is loaded — the AI will use it to answer your questions.</p>
                    }
                </div>
            }
            else
            {
                @foreach (ChatMessage msg in messages)
                {
                    <div class="message @(msg.Role == "user" ? "message-user" : (msg.IsError ? "message-error" : "message-assistant"))">
                        <div class="message-role">
                            @if (msg.Role == "user")
                            {
                                <span>🧑 You</span>
                            }
                            else if (msg.IsError)
                            {
                                <span>⚠️ Error</span>
                            }
                            else
                            {
                                <span>🤖 Assistant (@SelectedModelId)</span>
                            }
                            <small class="text-muted ms-2">@msg.Timestamp.ToLocalTime().ToString("HH:mm:ss")</small>
                        </div>
                        <div class="message-content">
                            @if (msg.Role == "user" || msg.IsError)
                            {
                                @msg.Content
                            }
                            else
                            {
                                @((MarkupString)ConvertToHtml(msg.Content))
                            }
                        </div>
                    </div>
                }

                @if (isSending)
                {
                    <div class="message message-assistant">
                        <div class="message-role"><span>🤖 Assistant</span></div>
                        <div class="message-content typing-indicator">
                            <span></span><span></span><span></span>
                        </div>
                    </div>
                }
            }
        </div>
    </div>

    <!-- Message Input -->
    <div class="card input-card">
        <div class="card-body">
            <div class="input-group">
                <textarea class="form-control"
                          placeholder="Type your message... (Shift+Enter for new line, Enter to send)"
                          rows="3"
                          @bind="userInput"
                          @bind:event="oninput"
                          @onkeydown="HandleKeyDown"
                          @onkeydown:preventDefault="@preventEnterDefault"
                          disabled="@isSending"></textarea>
                <button class="btn btn-primary send-btn" @onclick="SendMessageAsync" disabled="@(isSending || string.IsNullOrWhiteSpace(userInput))">
                    @if (isSending)
                    {
                        <span class="spinner-border spinner-border-sm" aria-hidden="true"></span>
                    }
                    else
                    {
                        <span>Send ➤</span>
                    }
                </button>
            </div>
            <div class="d-flex justify-content-between align-items-center mt-2">
                <small class="text-muted">Model: <strong>@SelectedModelId</strong></small>
                @if (messages.Any())
                {
                    <button class="btn btn-sm btn-outline-secondary" @onclick="ClearConversation" disabled="@isSending">
                        🗑️ Clear Conversation
                    </button>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private OpenRouterSettings settings = new();
    private string SelectedModelId { get; set; } = string.Empty;
    private readonly List<ChatMessage> messages = [];
    private string userInput = string.Empty;
    private bool isSending;
    private string? contextDocument;
    private string? contextFileName;
    private string fileError = string.Empty;
    private ElementReference messagesContainer;

    private static string ConvertToHtml(string markdown)
    {
        return Markdown.ToHtml(markdown);
    }

    protected override void OnInitialized()
    {
        settings = SettingsOptions.Value;
        if (settings.Models.Count > 0)
            SelectedModelId = settings.Models[0].Id;
    }

    private async Task HandleFileUploadAsync(InputFileChangeEventArgs e)
    {
        fileError = string.Empty;
        contextDocument = null;
        contextFileName = null;

        IBrowserFile file = e.File;
        if (file == null)
        {
            return;
        }

        try
        {
            await using Stream stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            contextDocument = await DocumentSvc.ExtractTextAsync(stream, file.Name, file.Size);
            contextFileName = file.Name;
        }
        catch (Exception ex)
        {
            fileError = ex.Message;
        }
    }

    private void ClearDocument()
    {
        contextDocument = null;
        contextFileName = null;
        fileError = string.Empty;
    }

    private bool preventEnterDefault;

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        switch (e.Key)
        {
            case "Enter" when !e.ShiftKey:
            {
                preventEnterDefault = true;
                if (!isSending && !string.IsNullOrWhiteSpace(userInput))
                    await SendMessageAsync();
                break;
            }
            case "Enter" when e.ShiftKey:
                // Allow Shift+Enter to insert a newline without sending
                preventEnterDefault = false;
                break;
            default:
                preventEnterDefault = false;
                break;
        }
    }

    private async Task SendMessageAsync()
    {
        string userText = userInput.Trim();
        if (string.IsNullOrEmpty(userText) || isSending) return;

        userInput = string.Empty;
        isSending = true;

        messages.Add(new ChatMessage { Role = "user", Content = userText });
        await ScrollToBottomAsync();

        try
        {
            // Pass the conversation history minus the just-added user message (it's included separately)
            List<ChatMessage> history = messages.Take(messages.Count - 1).ToList();
            ChatResult result = await OpenRouterSvc.ChatAsync(
                SelectedModelId,
                history,
                userText,
                contextDocument);

            messages.Add(new ChatMessage { Role = "assistant", Content = result.Content });
        }
        catch (Exception ex)
        {
            messages.Add(new ChatMessage
            {
                Role = "assistant",
                Content = $"Error: {ex.Message}",
                IsError = true
            });
        }
        finally
        {
            isSending = false;
            StateHasChanged();
            await ScrollToBottomAsync();
        }
    }

    private void ClearConversation()
    {
        messages.Clear();
        userInput = string.Empty;
    }

    private async Task ScrollToBottomAsync()
    {
        await Task.Yield();
        try
        {
            await Js.InvokeVoidAsync("scrollToBottom", messagesContainer);
        }
        catch
        {
            // Ignore JS interop errors (e.g., during pre-render)
        }
    }
}
