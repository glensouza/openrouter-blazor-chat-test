@page "/"
@rendermode InteractiveServer
@inject OpenRouterService OpenRouterSvc
@inject DocumentService DocumentSvc
@inject IOptions<OpenRouterSettings> SettingsOptions
@inject IJSRuntime JS
@using Microsoft.Extensions.Options

<PageTitle>OpenRouter Chat</PageTitle>

<div class="chat-container">
    <div class="chat-header">
        <h2>🤖 OpenRouter Chat</h2>
        <p class="text-muted">Chat with free OpenRouter models with optional document context (RAG)</p>
    </div>

    <!-- Model and Document Settings -->
    <div class="card mb-3 settings-card">
        <div class="card-body">
            <div class="row g-3 align-items-end">
                <div class="col-md-5">
                    <label class="form-label fw-semibold">Model</label>
                    <select class="form-select" @bind="SelectedModelId" disabled="@_isSending">
                        @foreach (var model in _settings.Models)
                        {
                            <option value="@model.Id">@model.DisplayName</option>
                        }
                    </select>
                </div>
                <div class="col-md-5">
                    <label class="form-label fw-semibold">
                        📄 Context Document
                        @if (_contextDocument != null)
                        {
                            <span class="badge bg-success ms-1">Loaded</span>
                        }
                    </label>
                    <InputFile class="form-control" OnChange="HandleFileUploadAsync" accept=".txt,.md,.csv,.json,.xml,.html,.htm,.pdf" disabled="@_isSending" />
                    @if (!string.IsNullOrEmpty(_fileError))
                    {
                        <div class="text-danger small mt-1">@_fileError</div>
                    }
                </div>
                <div class="col-md-2">
                    @if (_contextDocument != null)
                    {
                        <button class="btn btn-outline-danger w-100" @onclick="ClearDocument" disabled="@_isSending">
                            🗑️ Clear Doc
                        </button>
                    }
                </div>
            </div>

            @if (_contextDocument != null)
            {
                <div class="context-preview mt-2">
                    <small class="text-muted fw-semibold">📎 @_contextFileName — @_contextDocument.Length.ToString("N0") characters loaded as context</small>
                </div>
            }
        </div>
    </div>

    <!-- Chat Messages -->
    <div class="chat-messages card mb-3" @ref="_messagesContainer">
        <div class="card-body p-3">
            @if (_messages.Count == 0)
            {
                <div class="text-center text-muted py-5">
                    <div class="display-6 mb-2">💬</div>
                    <p>Start a conversation! Select a model above and type your message below.</p>
                    @if (_contextDocument != null)
                    {
                        <p class="text-success">✅ Document context is loaded — the AI will use it to answer your questions.</p>
                    }
                </div>
            }
            else
            {
                @foreach (var msg in _messages)
                {
                    <div class="message @(msg.Role == "user" ? "message-user" : (msg.IsError ? "message-error" : "message-assistant"))">
                        <div class="message-role">
                            @if (msg.Role == "user")
                            {
                                <span>🧑 You</span>
                            }
                            else if (msg.IsError)
                            {
                                <span>⚠️ Error</span>
                            }
                            else
                            {
                                <span>🤖 Assistant (@SelectedModelId)</span>
                            }
                            <small class="text-muted ms-2">@msg.Timestamp.ToLocalTime().ToString("HH:mm:ss")</small>
                        </div>
                        <div class="message-content">@msg.Content</div>
                    </div>
                }

                @if (_isSending)
                {
                    <div class="message message-assistant">
                        <div class="message-role"><span>🤖 Assistant</span></div>
                        <div class="message-content typing-indicator">
                            <span></span><span></span><span></span>
                        </div>
                    </div>
                }
            }
        </div>
    </div>

    <!-- Message Input -->
    <div class="card input-card">
        <div class="card-body">
            <div class="input-group">
                <textarea class="form-control"
                          placeholder="Type your message... (Shift+Enter for new line, Enter to send)"
                          rows="3"
                          @bind="_userInput"
                          @bind:event="oninput"
                          @onkeydown="HandleKeyDown"
                          disabled="@_isSending"></textarea>
                <button class="btn btn-primary send-btn" @onclick="SendMessageAsync" disabled="@(_isSending || string.IsNullOrWhiteSpace(_userInput))">
                    @if (_isSending)
                    {
                        <span class="spinner-border spinner-border-sm" aria-hidden="true"></span>
                    }
                    else
                    {
                        <span>Send ➤</span>
                    }
                </button>
            </div>
            <div class="d-flex justify-content-between align-items-center mt-2">
                <small class="text-muted">Model: <strong>@SelectedModelId</strong></small>
                @if (_messages.Any())
                {
                    <button class="btn btn-sm btn-outline-secondary" @onclick="ClearConversation" disabled="@_isSending">
                        🗑️ Clear Conversation
                    </button>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private OpenRouterSettings _settings = new();
    private string SelectedModelId { get; set; } = string.Empty;
    private List<ChatMessage> _messages = [];
    private string _userInput = string.Empty;
    private bool _isSending;
    private string? _contextDocument;
    private string? _contextFileName;
    private string _fileError = string.Empty;
    private ElementReference _messagesContainer;

    protected override void OnInitialized()
    {
        _settings = SettingsOptions.Value;
        if (_settings.Models.Count > 0)
            SelectedModelId = _settings.Models[0].Id;
    }

    private async Task HandleFileUploadAsync(InputFileChangeEventArgs e)
    {
        _fileError = string.Empty;
        _contextDocument = null;
        _contextFileName = null;

        var file = e.File;
        if (file == null) return;

        try
        {
            using var stream = file.OpenReadStream(maxAllowedSize: 10 * 1024 * 1024);
            _contextDocument = await DocumentSvc.ExtractTextAsync(stream, file.Name);
            _contextFileName = file.Name;
        }
        catch (Exception ex)
        {
            _fileError = ex.Message;
        }
    }

    private void ClearDocument()
    {
        _contextDocument = null;
        _contextFileName = null;
        _fileError = string.Empty;
    }

    private async Task HandleKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey && !_isSending && !string.IsNullOrWhiteSpace(_userInput))
        {
            await SendMessageAsync();
        }
    }

    private async Task SendMessageAsync()
    {
        string userText = _userInput.Trim();
        if (string.IsNullOrEmpty(userText) || _isSending) return;

        _userInput = string.Empty;
        _isSending = true;

        _messages.Add(new ChatMessage { Role = "user", Content = userText });
        await ScrollToBottomAsync();

        try
        {
            // Pass the conversation history minus the just-added user message (it's included separately)
            var history = _messages.Take(_messages.Count - 1).ToList();
            string reply = await OpenRouterSvc.ChatAsync(
                SelectedModelId,
                history,
                userText,
                _contextDocument);

            _messages.Add(new ChatMessage { Role = "assistant", Content = reply });
        }
        catch (Exception ex)
        {
            _messages.Add(new ChatMessage
            {
                Role = "assistant",
                Content = $"Error: {ex.Message}",
                IsError = true
            });
        }
        finally
        {
            _isSending = false;
            StateHasChanged();
            await ScrollToBottomAsync();
        }
    }

    private void ClearConversation()
    {
        _messages.Clear();
        _userInput = string.Empty;
    }

    private async Task ScrollToBottomAsync()
    {
        await Task.Yield();
        try
        {
            await JS.InvokeVoidAsync("scrollToBottom", _messagesContainer);
        }
        catch
        {
            // Ignore JS interop errors (e.g., during pre-render)
        }
    }
}
